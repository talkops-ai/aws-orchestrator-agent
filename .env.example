GOOGLE_API_KEY="your-google-api-key"
GOOGLE_GENAI_USE_VERTEXAI="true" # If you are planning to use vertex ai
#In case you want to enable langsmith tracing
LANGCHAIN_API_KEY="your-langchain-api-key"
#Langchain Details
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="langsmith-project-key"
# Physical path for modules; virtual agent path is /workspace/terraform_modules/ under AGENT_PROJECT_ROOT
TERRAFORM_WORKSPACE=./workspace/terraform_modules

# Runtime context (injected into agent context_schema)
ENVIRONMENT=development


# Retries
MAX_RETRIES=10
# Backend
BACKEND_TYPE=filesystem
# Sandbox
SANDBOX_PROVIDER=local
# GitHub (for MCP server)
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp
GITHUB_PERSONAL_ACCESS_TOKEN="your-github-personal-access-token"
GITHUB_REPO=talkops-ai/terraform-example-modules
GITHUB_BRANCH=dev

# ── LLM: Standard (fast, cost-effective for validation) ──
LLM_PROVIDER="google_genai"
LLM_MODEL="gemini-3.1-flash-lite-preview"
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=15000

# ── LLM: Higher-tier (Planner & Supervisor routing) ──
LLM_HIGHER_PROVIDER="google_genai"
LLM_HIGHER_MODEL="gemini-3.1-pro-preview"
LLM_HIGHER_TEMPERATURE=0.0
LLM_HIGHER_MAX_TOKENS=15000
# ── LLM: DeepAgent (Coordinator & multi-step coding generation) ──
LLM_DEEPAGENT_PROVIDER="google_genai"
LLM_DEEPAGENT_MODEL="gemini-3.1-pro-preview"
LLM_DEEPAGENT_TEMPERATURE=1.0
LLM_DEEPAGENT_MAX_TOKENS=25000

LOG_LEVEL="DEBUG"